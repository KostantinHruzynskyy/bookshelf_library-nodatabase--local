{
  "name": "bookshelf-library",
  "version": "1.0.0",
  "description": "A digital bookshelf library with wooden UI — add, edit, delete and read books",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node tests/test-all.js",
    "test:security": "node test_security.js",
    "test:server": "node test_server.js",
    "test:e2e": "playwright test",
    "backup": "node scripts/backup.js",
    "health": "node scripts/health.js",
    "lint": "eslint src/ public/js/",
    "fix:lineendings": "find . -name '*.js' -not -path '*/node_modules/*' -not -path '*/.git/*' -exec sed -i 's/\\r$//' {} +"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "json2csv": "^6.0.0-alpha.2",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "sharp": "^0.35.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "eslint": "^10.6.0",
    "nodemon": "^3.1.14"
  }
}
