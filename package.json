{
  "name": "bookshelf-library",
  "version": "1.0.0",
  "description": "A digital bookshelf library with wooden UI — add, edit, delete and read books",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node tests/test-all.js",
    "test:security": "node test_security.js",
    "test:server": "node test_server.js",
    "fix:lineendings": "find . -name '*.js' -not -path '*/node_modules/*' -not -path '*/.git/*' -exec sed -i 's/\\r$//' {} +",
    "lint": "find . -name '*.js' -not -path '*/node_modules/*' -not -path '*/.git/*' -exec node -c {} \\;"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "multer": "^2.1.1"
  }
}
