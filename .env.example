# ==========================================
# Bookshelf Library - Environment Configuration
# ==========================================
# IMPORTANT: Copy this file to .env and update values
# NEVER commit .env to version control!

# ---- Server ----
NODE_ENV=development
PORT=3000

# ---- Database ----
# Options: sqlite, postgresql, mysql
DB_TYPE=sqlite
DB_PATH=./bookshelf.db

# PostgreSQL (uncomment to use)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=bookshelf
# DB_USER=postgres
# DB_PASSWORD=changeme
# DB_SSL=false

# MySQL (uncomment to use)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=bookshelf
# DB_USER=root
# DB_PASSWORD=changeme

# ---- Security ----
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-random-string
JWT_SECRET=change-me-to-random-string
BCRYPT_ROUNDS=12

# ---- File Uploads ----
MAX_FILE_SIZE=52428800

# ---- Logging ----
LOG_LEVEL=info

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=200

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000

# ---- Backup ----
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7

# ---- Optional Services ----
# Redis for caching: redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn

# ---- First Run ----
# Admin account is created automatically on first run
# Default: admin@bookshelf.com / admin123
# Change after first login!
ADMIN_EMAIL=admin@bookshelf.com
ADMIN_PASSWORD=admin123