# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly declare text files
*.js text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Binary files
*.db binary
*.db-shm binary
*.db-wal binary
*.pdf binary
*.epub binary
*.mobi binary
*.zip binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
